#vEnvironment Variables
# Copy this file to .env and fill in your values
# Load with: export $(cat .env | xargs)  OR use python-dotenv

# ── MySQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=smart_farmer_db

# ── Flask ──────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
